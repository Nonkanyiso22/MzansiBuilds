@model IEnumerable<MzansiBuilds.Models.Project>

@{
    ViewData["Title"] = "Celebration Wall";
}

<div class="container mt-4">

    <!-- HEADER -->
    <div class="text-center mb-5">
        <h1 class="fw-bold text-success">🎉 Celebration Wall</h1>
        <p class="text-muted">Showcasing completed projects and achievements</p>
    </div>

    @if (!Model.Any())
    {
        <div class="text-center">
            <p>No projects completed yet. Keep building in public! 🚀</p>
        </div>
    }
    else
    {
        <div class="row justify-content-center">
            <div class="col-md-8">

                @foreach (var project in Model)
                {
                    <div class="card mb-4 shadow-soft">

                        <!-- HEADER -->
                        <div class="card-header d-flex justify-content-between align-items-center bg-success text-white">
                            <h5 class="mb-0">@project.Title</h5>
                            <small>@project.CreatedAt.ToString("yyyy-MM-dd")</small>
                        </div>

                        <!-- BODY -->
                        <div class="card-body">

                            <!-- DESCRIPTION -->
                            <p class="text-muted">@project.Description</p>

                            <!-- OWNER -->
                            <p><strong>👤 Owner:</strong> @project.UserId</p>

                            <!-- MILESTONES -->
                            @if (project.Milestones != null && project.Milestones.Any())
                            {
                                <div class="mt-3">
                                    <h6 class="text-success">🏆 Milestones Achieved</h6>
                                    <ul class="list-group list-group-flush">
                                        @foreach (var m in project.Milestones)
                                        {
                                            <li class="list-group-item">
                                                ✅ @m.Description
                                                <small class="text-muted d-block">
                                                    @m.AchievedAt.ToString("yyyy-MM-dd")
                                                </small>
                                            </li>
                                        }
                                    </ul>
                                </div>
                            }

                            <!-- COMMENTS -->
                            @if (project.Comments != null && project.Comments.Any())
                            {
                                <div class="mt-3">
                                    <h6 class="text-success">💬 Community Feedback</h6>
                                    <ul class="list-group list-group-flush">
                                        @foreach (var c in project.Comments)
                                        {
                                            <li class="list-group-item">
                                                <strong>@c.UserId:</strong> @c.Content
                                            </li>
                                        }
                                    </ul>
                                </div>
                            }

                        </div>

                    </div>
                }

            </div>
        </div>
    }
</div>