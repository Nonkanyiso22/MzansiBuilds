@model IEnumerable<MzansiBuilds.Models.Project>

@{
    ViewData["Title"] = "MzansiBuilds - Feed";
}

<div class="container mt-4">

    <!-- HEADER -->
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2 class="text-success fw-bold">MzansiBuilds - Feed</h2>
        <div>
            <a class="btn btn-success me-2" asp-action="Create">+ New Project</a>
            <a class="btn btn-dark" asp-action="CelebrationWall">🎉 Celebration Wall</a>
        </div>
    </div>

    @if (!Model.Any())
    {
        <div class="text-center text-muted">
            <p>No projects yet. Start building and share your progress! 🚀</p>
        </div>
    }
    else
    {
        <div class="row row-cols-1 row-cols-md-2 g-4">

            @foreach (var project in Model)
            {
                <div class="col">
                    <div class="card h-100 border-success shadow-sm">
                        <div class="card-header bg-success text-white d-flex justify-content-between">
                            <strong>@project.Title</strong>
                            <span>Stage: @project.Stage</span>
                        </div>
                        <div class="card-body">
                            <p class="text-dark">@project.Description</p>
                            <p><strong>Owner:</strong> @project.UserId</p>

                            <!-- Milestones -->
                            <div class="mt-2">
                                <h6>🏆 Milestones</h6>
                                @if (project.Milestones != null && project.Milestones.Any())
                                {
                                    <ul class="ms-3">
                                        @foreach (var m in project.Milestones)
                                        {
                                            <li>@m.Description (@m.AchievedAt.ToShortDateString())</li>
                                        }
                                    </ul>
                                }
                                else
                                {
                                    <p class="text-muted">No milestones yet.</p>
                                }
                            </div>

                            <!-- Comments -->
                            <div class="mt-2">
                                <h6>💬 Comments</h6>
                                @if (project.Comments != null && project.Comments.Any())
                                {
                                    <ul class="ms-3">
                                        @foreach (var c in project.Comments)
                                        {
                                            <li><strong>@c.UserId:</strong> @c.Content</li>
                                        }
                                    </ul>
                                }
                                else
                                {
                                    <p class="text-muted">No comments yet.</p>
                                }
                            </div>

                            <!-- Add Comment -->
                            <form asp-action="AddComment" method="post" class="mt-2 d-flex">
                                <input type="hidden" name="ProjectId" value="@project.Id" />
                                <input type="text" name="Content" class="form-control me-2" placeholder="Add a comment..." required />
                                <button type="submit" class="btn btn-primary btn-sm">Post</button>
                            </form>

                            <!-- Add Milestone -->
                            <form asp-action="AddMilestone" method="post" class="mt-2 d-flex">
                                <input type="hidden" name="ProjectId" value="@project.Id" />
                                <input type="text" name="Description" class="form-control me-2" placeholder="Add a milestone..." required />
                                <button type="submit" class="btn btn-info btn-sm">Add</button>
                            </form>

                            <!-- Raise Hand / Collaboration -->
                            <form asp-action="RequestCollaboration" method="post" class="mt-2">
                                <input type="hidden" name="ProjectId" value="@project.Id" />
                                <button type="submit" class="btn btn-warning btn-sm w-100">
                                    @(project.CollaborationRequested ? "Collaboration Requested" : "Raise Hand")
                                </button>
                            </form>

                            <!-- Mark as Completed -->
                            @if (project.Stage != "Completed" && project.UserId == User.Identity.Name)
                            {
                                <form asp-action="MarkCompleted" method="post" class="mt-2">
                                    <input type="hidden" name="ProjectId" value="@project.Id" />
                                    <button type="submit" class="btn btn-success btn-sm w-100">Mark as Completed</button>
                                </form>
                            }
                        </div>
                    </div>
                </div>
            }
        </div>
    }
</div>