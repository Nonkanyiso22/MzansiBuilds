@model MzansiBuilds.Models.Project

@{
    ViewData["Title"] = "Project Details";
}

<div class="container mt-4">

    <!-- HEADER -->
    <div class="mb-4 text-center">
        <h1 class="fw-bold">📌 Project Details</h1>
        <p class="text-muted">View full information about this project</p>
    </div>

    <!-- PROJECT CARD -->
    <div class="row justify-content-center">
        <div class="col-md-8">
            <div class="card p-4 shadow-soft">

                <!-- TITLE -->
                <h2 class="fw-bold text-success">@Model.Title</h2>
                <hr />

                <!-- DESCRIPTION -->
                <div class="mb-3">
                    <h5 class="fw-semibold">📝 Description</h5>
                    <p class="text-muted">@Model.Description</p>
                </div>

                <!-- STAGE -->
                <div class="mb-3">
                    <h5 class="fw-semibold">🚧 Stage</h5>
                    <span class="badge bg-success">@Model.Stage</span>
                </div>

                <!-- SUPPORT -->
                <div class="mb-3">
                    <h5 class="fw-semibold">🤝 Support Needed</h5>
                    <p>@Model.SupportNeeded</p>
                </div>

                <!-- CREATED DATE -->
                <div class="mb-3">
                    <h5 class="fw-semibold">📅 Created</h5>
                    <p class="text-muted">@Model.CreatedAt.ToString("yyyy-MM-dd")</p>
                </div>

                <!-- USER (OPTIONAL DISPLAY) -->
                <div class="mb-3">
                    <h5 class="fw-semibold">👤 Owner</h5>
                    <p class="text-muted">@Model.UserId</p>
                </div>

                <!-- ACTION BUTTONS -->
                <div class="d-flex justify-content-between mt-4">
                    <a asp-action="Index" class="btn btn-outline-dark">
                        ← Back
                    </a>

                    <a asp-action="Edit" asp-route-id="@Model?.Id" class="btn btn-success">
                        ✏️ Edit Project
                    </a>
                </div>

            </div>
        </div>
    </div>

</div>
